# Backend Environment Variables
# Copy this file to .env and fill in your values.

# Server settings
PORT=5000
NODE_ENV=development

# Database
# Primary variable: MONGO_URI
# Alias supported for compatibility: MONGODB_URI
MONGO_URI=mongodb://127.0.0.1:27017/fashion_shaa_pos

# Optional comma-separated web origins for browser clients.
# Electron/file origins are allowed automatically.
# Example:
# CORS_ORIGIN=https://your-service.onrender.com,https://admin.example.com
CORS_ORIGIN=

# Google Gemini AI Key (for sales analytics)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Authentication
JWT_SECRET=your_random_secret_key_here_minimum_32_chars
# Primary variable: JWT_EXPIRY
# Alias supported for compatibility: JWT_EXPIRES_IN
JWT_EXPIRY=12h

# Backend Environment Variables
# Copy this file to .env and fill in your values.

# Server settings
PORT=5000
NODE_ENV=development

# Database
# Modes:
# - local  -> use only MONGO_LOCAL_URI
# - remote -> use only MONGO_REMOTE_URI
# - auto   -> try remote first, then fall back to local
# - single -> use MONGO_URI / MONGODB_URI only
MONGO_CONNECTION_MODE=auto

# Local MongoDB
MONGO_LOCAL_URI=mongodb://127.0.0.1:27017/fashion_shaa_pos

# Remote MongoDB / MongoDB Atlas
MONGO_REMOTE_URI=

# Legacy single-URI support is still available for compatibility.
MONGO_URI=

# Optional sync between local and remote.
# When enabled and both URIs are configured, the active database syncs to the standby database.
MONGO_SYNC_ENABLED=false
MONGO_SYNC_ON_STARTUP=true
MONGO_SYNC_INTERVAL_MS=60000

# Optional comma-separated web origins for browser clients.
# Electron/file origins are allowed automatically.
# Example:
# CORS_ORIGIN=https://your-service.onrender.com,https://admin.example.com
CORS_ORIGIN=

# Google Gemini AI Key (for sales analytics)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Authentication
JWT_SECRET=your_random_secret_key_here_minimum_32_chars
# Primary variable: JWT_EXPIRY
# Alias supported for compatibility: JWT_EXPIRES_IN
JWT_EXPIRY=12h
